<h1>Login</h1>

<form action="/sessions" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <p>
    <label>Email</label>
    <input type="text" name="email">
  </p>

  <p>
    <label>Password</label>
    <input type="password" name="password">
  </p>

  <button>Login<button>
</form>
